<!DOCTYPE html>
<html lang="de" data-theme="dark">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1,viewport-fit=cover">
<meta name="apple-mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
<meta name="apple-mobile-web-app-title" content="Squeeze Report">
<meta name="theme-color" content="#0d1117">
<link rel="icon" type="image/svg+xml" href="favicon.svg">
<title>Squeeze Report – {{ report_date }}</title>
<!-- Lucide Icons (https://lucide.dev) — Mobile-Navigation Hamburger-Menü.
     defer: lädt nicht-blockierend; createIcons() wird nach DOMContentLoaded
     aufgerufen (siehe runtime-JS am Seitenende). -->
<script src="https://unpkg.com/lucide@latest" defer></script>
<style>
:root{
  --bg:#f1f5f9;--bg-card:#fff;--bg-hdr:#fff;--bg-met:#f8fafc;
  --txt:#1e293b;--txt-sub:#64748b;--txt-dim:#94a3b8;
  --brd:#e2e8f0;--shadow:0 2px 8px rgba(0,0,0,.07);
  --accent:#3b82f6;--radius:14px;
  --red:#ef4444;--ora:#f59e0b;--grn:#22c55e;
  --disc-col:#c2410c;
  --base-font-size:15px;
}
html{font-size:var(--base-font-size)}
html[data-theme="dark"]{
  --bg:#0a0c12;--bg-card:#141929;--bg-hdr:#0d1117;--bg-met:#1a2035;
  --txt:#e2e8f0;--txt-sub:#94a3b8;--txt-dim:#64748b;
  --brd:#1e2d4a;--shadow:0 2px 12px rgba(0,0,0,.35);
  --disc-col:#ca8a04;
}
*{box-sizing:border-box;margin:0;padding:0;-webkit-tap-highlight-color:transparent}
body{font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,sans-serif;
  background:var(--bg);color:var(--txt);min-height:100vh;font-size:1rem;overflow-x:hidden}
a{color:var(--accent);text-decoration:none}
/* ── Sticky header – full width on all screens ── */
.app-hdr{position:sticky;top:0;z-index:100;background:var(--bg-hdr);
  border-bottom:1px solid var(--brd);padding:0 16px;
  padding-top:env(safe-area-inset-top);
  box-shadow:0 1px 4px rgba(0,0,0,.0);width:100%;
  transition:box-shadow .2s}
.app-hdr.scrolled{box-shadow:0 2px 12px rgba(0,0,0,.18)}
/* Mobile-first: row1 = title (links) + Hamburger (rechts);
   row2 = timestamp (volle Breite, via .hdr-ts{order:3;width:100%}) */
.hdr-main{display:flex;flex-wrap:wrap;align-items:center;gap:8px;padding:10px 0}
.app-title{font-size:1.05rem;font-weight:800;color:var(--txt);flex:1;order:1;min-width:0;
  white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.app-title span{color:var(--accent)}
/* Hamburger-Button — Touch-Target 44×44, rechts neben Title */
.hamburger-btn{order:2;flex-shrink:0;width:44px;height:44px;
  background:transparent;border:1px solid var(--brd);border-radius:8px;
  display:inline-flex;align-items:center;justify-content:center;
  cursor:pointer;color:var(--txt);transition:background .15s,border-color .15s}
.hamburger-btn:hover,.hamburger-btn:focus-visible{background:var(--bg-met);outline:none;border-color:var(--accent)}
.hamburger-btn:active{transform:scale(.96)}
.hamburger-icon{width:24px;height:24px;stroke-width:2}
/* Backdrop */
.menu-overlay{position:fixed;inset:0;background:rgba(0,0,0,.45);
  z-index:298;display:none}
.menu-overlay.open{display:block}
/* Drawer von oben rechts */
.menu-drawer{position:fixed;top:0;right:0;width:240px;max-width:90vw;
  background:var(--bg-card);color:var(--txt);
  border:1px solid var(--brd);border-top:0;border-right:0;
  box-shadow:-4px 4px 24px rgba(0,0,0,.35);
  display:flex;flex-direction:column;z-index:299;
  padding-top:max(12px, env(safe-area-inset-top));
  padding-bottom:max(12px, env(safe-area-inset-bottom));
  transform:translateY(-110%) translateX(0);
  transition:transform .25s cubic-bezier(.4,0,.2,1);
  pointer-events:none}
.menu-drawer.open{transform:translateY(0);pointer-events:auto}
.menu-list{display:flex;flex-direction:column;gap:2px;padding:8px 8px}
.menu-item{display:flex;align-items:center;gap:12px;
  background:transparent;border:none;border-radius:8px;
  padding:10px 12px;text-align:left;cursor:pointer;
  color:var(--txt);font-size:.92rem;font-weight:500;
  font-family:inherit;width:100%;min-height:44px}
.menu-item:hover,.menu-item:focus-visible{background:var(--bg-met);outline:none}
.menu-item:active{background:var(--brd)}
.menu-item-primary{color:#67e8f9}
.menu-item-primary .menu-icon-box{background:#0e3a5e;color:#67e8f9}
.menu-icon-box{flex-shrink:0;width:28px;height:28px;border-radius:7px;
  background:#11203a;color:#4a9eff;
  display:inline-flex;align-items:center;justify-content:center}
.menu-icon-box i{width:18px;height:18px;stroke-width:2}
.menu-label{flex:1;min-width:0;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.menu-chevron{width:16px;height:16px;color:var(--txt-dim);transition:transform .2s}
/* HTML hidden-Attribut MUSS display:flex überschreiben — sonst bleibt das
   Submenu trotz hidden-Attribut sichtbar (CSS-Spec: hidden-Attribut hat
   nur User-Agent-Default display:none, das von expliziten Display-Werten
   überschrieben wird). */
.menu-submenu[hidden]{display:none}
.menu-submenu{display:flex;flex-direction:column;gap:1px;padding:2px 8px 6px 48px}
.menu-subitem{display:flex;align-items:center;gap:8px;
  background:transparent;border:none;border-radius:6px;
  padding:8px 10px;cursor:pointer;color:var(--txt-sub);
  font-family:inherit;font-size:.85rem;text-align:left;width:100%;min-height:36px}
.menu-subitem:hover,.menu-subitem:focus-visible{background:var(--bg-met);color:var(--txt);outline:none}
.menu-check{width:14px;height:14px;color:var(--accent);flex-shrink:0;visibility:hidden}
.menu-footer{display:flex;gap:6px;padding:10px 12px 4px;
  border-top:1px solid var(--brd);margin-top:6px;justify-content:space-around}
.menu-foot-btn{flex:1;min-height:40px;
  background:transparent;border:1px solid var(--brd);border-radius:6px;
  color:var(--txt-sub);cursor:pointer;
  display:inline-flex;align-items:center;justify-content:center}
.menu-foot-btn:hover,.menu-foot-btn:focus-visible{background:var(--bg-met);color:var(--txt);outline:none;border-color:var(--accent)}
.menu-foot-btn i{width:18px;height:18px;stroke-width:2}
@media(min-width:768px){
  .menu-drawer{width:280px}
}
/* Timestamp im Header. Mobile: wraps zur 2. Reihe (width:100%);
   Desktop ≥768 px: zentriert in row 1 zwischen Title und Hamburger
   (Override im Desktop-Block). */
.hdr-ts{font-size:.73rem;color:var(--txt-sub);width:100%;order:3}
/* Inline-Hinweis an Wochenenden / US-Feiertagen — dezent neben dem
   Zeitstempel, kein prominentes Banner. Nur sichtbar wenn JS das
   ``hidden``-Attribut entfernt (siehe Non-trading-day status-IIFE). */
.hdr-nontrading{display:inline-flex;align-items:center;
  margin-left:8px;padding:1px 7px;border-radius:10px;
  font-size:.7rem;font-weight:600;letter-spacing:.02em;
  color:#f59e0b;background:rgba(245,158,11,.10);
  border:1px solid rgba(245,158,11,.35);white-space:nowrap;cursor:help}
.hdr-nontrading[hidden]{display:none}
.btn{display:inline-flex;align-items:center;justify-content:center;
  gap:6px;min-height:44px;padding:0 16px;border:1px solid transparent;border-radius:6px;
  font-size:.9rem;font-weight:700;cursor:pointer;flex:1;
  transition:opacity .15s,transform .1s,background .15s,color .15s;white-space:nowrap}
.btn:active{transform:scale(.96)}
.btn:disabled{opacity:.45;cursor:not-allowed;transform:none}
.btn-g{background:#164e63;color:#a5f3fc;border:1px solid #0e7490}
.btn-g:hover:not(:disabled){background:#334155;color:#e2e8f0}
.btn-b{background:#1e293b;color:#94a3b8;border:1px solid #334155}
.btn-b:hover:not(:disabled){background:#334155;color:#e2e8f0}
.btn-ki{background:#1e293b;color:#94a3b8;border:1px solid #334155}
.btn-ki:hover:not(:disabled){background:#334155;color:#e2e8f0}
select.sort-select{appearance:none;-webkit-appearance:none;-moz-appearance:none;
  font-family:inherit;padding-right:28px;
  background-image:linear-gradient(45deg,transparent 50%,#94a3b8 50%),linear-gradient(135deg,#94a3b8 50%,transparent 50%);
  background-position:calc(100% - 14px) 50%,calc(100% - 9px) 50%;
  background-size:5px 5px,5px 5px;background-repeat:no-repeat}
select.sort-select:hover:not(:disabled){background-image:linear-gradient(45deg,transparent 50%,#e2e8f0 50%),linear-gradient(135deg,#e2e8f0 50%,transparent 50%)}
/* token panel */
.tok-panel{padding:0 0 10px}
.tok-hint{font-size:.8rem;color:var(--txt-sub);margin-bottom:8px;line-height:1.5}
.tok-row{display:flex;gap:8px;flex-wrap:wrap}
.tok-inp{flex:1;min-width:180px;background:var(--bg-met);border:1px solid var(--brd);
  border-radius:8px;color:var(--txt);padding:0 12px;height:44px;
  font-size:.85rem;font-family:monospace}
.tok-inp:focus{outline:2px solid var(--accent);outline-offset:1px}
.tok-link{font-size:.75rem;color:var(--txt-dim);padding:4px 2px;cursor:pointer}
/* ── Token-Encryption-Modals (Phase 3) ─────────────────────────────── */
.tok-modal-overlay{position:fixed;inset:0;background:rgba(0,0,0,.55);
  z-index:9000}
.tok-modal-overlay[hidden]{display:none}
.tok-modal{position:fixed;top:50%;left:50%;transform:translate(-50%,-50%);
  z-index:9001;background:var(--bg-card);border:1px solid var(--brd);
  border-radius:12px;padding:18px 20px;
  width:min(420px, calc(100vw - 32px));
  box-shadow:0 12px 32px rgba(0,0,0,.5)}
.tok-modal[hidden]{display:none}
.tok-modal h3{margin:0 0 8px;font-size:1.05rem;font-weight:800;color:var(--txt)}
.tok-modal-hint{font-size:.78rem;color:var(--txt-sub);line-height:1.5;
  margin:0 0 12px}
.tok-modal-hint code{background:var(--bg-met);padding:1px 5px;border-radius:4px;
  font-size:.92em;border:1px solid var(--brd)}
.tok-modal-lbl{display:flex;flex-direction:column;gap:4px;
  font-size:.72rem;color:var(--txt-sub);font-weight:600;margin-bottom:10px}
.tok-modal-inp{background:var(--bg-met);border:1px solid var(--brd);
  border-radius:6px;padding:8px 10px;color:var(--txt);font-size:.85rem;
  font-family:inherit;min-height:38px}
.tok-modal-inp:focus{outline:2px solid var(--accent);outline-offset:1px}
.tok-modal-err{background:rgba(239,68,68,0.12);border:1px solid rgba(239,68,68,0.45);
  color:#ef4444;border-radius:6px;padding:8px 10px;font-size:.78rem;
  line-height:1.45;margin:4px 0 10px;font-weight:600}
.tok-modal-err[hidden]{display:none}
.tok-modal-btns{display:flex;flex-wrap:wrap;align-items:center;gap:8px;
  justify-content:flex-end;margin-top:10px}
.tok-modal-reset{font-size:.72rem;color:#f59e0b;cursor:pointer;
  margin-right:auto;text-decoration:underline}
.tok-modal .btn{flex:0 0 auto;min-height:38px;padding:0 14px;
  border-radius:8px;font-size:.85rem;font-weight:700;cursor:pointer;
  border:1px solid var(--brd)}
.tok-modal .btn-cancel{background:transparent;color:var(--txt-sub)}
.tok-modal .btn-cancel:hover{background:var(--bg-met)}
.tok-modal .btn-b{background:#2563eb;color:#fff;border-color:#2563eb}
.tok-modal .btn-b:hover:not(:disabled){background:#1d4ed8}
.amsg{margin-top:8px;padding:10px 13px;border-radius:8px;font-size:.8rem;line-height:1.5;display:flex;align-items:center}
.amsg-success{background:#052a14;border:1px solid #166534;color:#86efac}
.amsg-error{background:#2d0a0a;border:1px solid #991b1b;color:#fca5a5}
.amsg-info{background:#0c1a30;border:1px solid #1e3a5f;color:#93c5fd}
@keyframes poll-pulse{0%,100%{opacity:1}50%{opacity:.35}}
.poll-dot{display:inline-block;width:8px;height:8px;border-radius:50%;
  margin-right:8px;flex-shrink:0}
.poll-dot-run{background:#f59e0b;animation:poll-pulse 1.2s ease-in-out infinite}
.poll-dot-done{background:#22c55e}
.poll-dot-err{background:#ef4444}
.amsg-poll-running{background:#1c1200;border:1px solid #92400e;color:#fcd34d}
.amsg-poll-done{background:#052a14;border:1px solid #166534;color:#86efac;align-items:flex-start}
.amsg-cd-body{flex:1;display:flex;flex-direction:column;gap:5px}
.amsg-cd-title{font-weight:700;font-size:.85rem}
.amsg-cd-sub{font-size:.75rem;opacity:.85;line-height:1.5}
.amsg-cd-bar-wrap{height:4px;background:rgba(255,255,255,.15);border-radius:2px;overflow:hidden;margin-top:2px}
.amsg-cd-bar{height:100%;background:#22c55e;border-radius:2px;transition:width 1s linear}
.amsg-cd-btn{margin-top:8px;align-self:flex-start;background:#22c55e;color:#052a14;border:none;
  border-radius:6px;padding:6px 14px;font-size:.78rem;font-weight:700;cursor:pointer;min-height:36px}
/* ── Container – fluid, no max-width ── */
.wrap{padding:16px 14px 32px}
/* ── Stats bar ── */
.stats-bar{display:grid;grid-template-columns:repeat(3,1fr);gap:8px;margin-bottom:14px}
.stat-title{grid-column:1 / -1;background:#042C53;border-radius:10px;
  padding:11px 8px;text-align:center;color:#E6F1FB;font-size:1.19rem;font-weight:500}
.stat-box{background:var(--bg-card);border:1px solid var(--brd);border-radius:10px;
  padding:10px 8px;text-align:center}
.stat-val{display:block;font-size:1.05rem;font-weight:800;color:var(--accent)}
.stat-lbl{display:block;font-size:.62rem;color:var(--txt-dim);text-transform:uppercase;
  letter-spacing:.4px;margin-top:2px}
/* ── Info panel ── (Score-Methodik & Filterkriterien als reguläre
   <section>; früher <details>/<summary>-Drop-Down, ist nach UI-Refactor
   immer offen. Scrolling via Hamburger-Menü → scrollToMethodology). */
.info-panel{background:var(--bg-card);border:1px solid var(--brd);border-radius:var(--radius);
  margin-bottom:12px;overflow:hidden;padding-top:14px}
/* Standardmäßig hidden — wird via Hamburger-Menü → scrollToMethodology
   eingeblendet. HTML hidden-Attribut + display:none-Override, damit nicht
   andere Display-Properties (wie display:block) durchschlagen. */
.info-panel[hidden]{display:none}
/* Head: Title links, Schließen-Button rechts (44×44 Touch-Target). */
.info-panel-head{display:flex;align-items:center;justify-content:space-between;
  padding:0 12px 10px;gap:8px}
.info-panel-title{font-size:.83rem;font-weight:700;
  color:var(--txt-sub);text-transform:none;letter-spacing:0;margin:0;
  padding:0 4px}
.info-panel-close{background:transparent;border:1px solid var(--brd);
  border-radius:6px;width:36px;height:36px;cursor:pointer;
  color:var(--txt-sub);flex-shrink:0;
  display:inline-flex;align-items:center;justify-content:center}
.info-panel-close:hover,.info-panel-close:focus-visible{background:var(--bg-met);color:var(--txt);outline:none;border-color:var(--accent)}
.info-panel-close i{width:18px;height:18px;stroke-width:2}
/* Mobile: single column; tablet+ overrides to 3 */
.info-inner{display:grid;grid-template-columns:1fr;gap:10px;padding:0 12px 14px}
.info-box{background:var(--bg-met);border-radius:8px;padding:10px 12px}
.info-box--full{grid-column:1 / -1}
.info-box h4{font-size:.67rem;text-transform:uppercase;letter-spacing:.5px;
  color:var(--accent);margin-bottom:7px}
.info-box ul{list-style:none;display:flex;flex-direction:column;gap:4px}
.info-box li{font-size:.77rem;color:var(--txt-sub);line-height:1.5;
  padding-left:12px;position:relative}
.info-box li::before{content:"–";position:absolute;left:0;color:var(--accent)}
/* ── Score-Methodik: drei Hauptblöcke als visuelle Karten ── */
.score-blocks{display:grid;grid-template-columns:1fr;gap:10px}
@media(min-width:600px){.score-blocks{grid-template-columns:repeat(3,1fr)}}
.score-block-card{background:var(--bg-card);border:1px solid var(--brd);
  border-radius:8px;padding:10px 12px;display:flex;flex-direction:column;gap:8px}
.score-block-head{display:flex;align-items:center;justify-content:space-between;
  gap:8px;border-bottom:1px solid var(--brd);padding-bottom:6px}
.score-block-name{font-size:.92rem;font-weight:800;color:var(--txt);
  letter-spacing:.01em}
.score-block-badge{flex-shrink:0;font-size:.68rem;font-weight:700;
  letter-spacing:.04em;padding:3px 8px;border-radius:10px;
  background:var(--bg-met);color:var(--accent);
  border:1px solid var(--brd);font-variant-numeric:tabular-nums}
.score-block-list{list-style:none;margin:0;padding:0;display:flex;flex-direction:column;
  gap:5px}
.score-block-list li{display:flex;align-items:baseline;justify-content:space-between;
  gap:8px;font-size:.78rem;color:var(--txt-sub);line-height:1.45;
  padding:0;position:static}
.score-block-list li::before{content:none}
.sb-lbl{flex:1;min-width:0}
.sb-pts{flex-shrink:0;font-weight:700;font-variant-numeric:tabular-nums;
  color:var(--txt);font-size:.74rem}
.score-block-foot{font-size:.7rem;color:var(--txt-dim);margin:0;
  padding-top:4px;border-top:1px dashed var(--brd);line-height:1.5}
.score-block-foot-strong{color:var(--txt-sub);
  border-top:1px solid var(--brd);padding-top:8px}
.score-block-intro{font-size:.78rem;color:var(--txt-sub);margin:0 0 10px;
  line-height:1.5;font-style:italic}
/* KI-Agent-Tabellen: technische Werte (z. B. „×1.10 / ×1.20 …"
   oder „≥5× heute & ≥2× vs. Vortag") in Mono-Font, damit Trigger und
   Schwellen visuell besser ausgerichtet bleiben. Greift nur, wenn
   die ``score-blocks`` mit ``ki-agent-blocks`` modifiziert sind —
   die Score-Formel-Pills oben behalten den Standard-Tabular-Look. */
.ki-agent-blocks .sb-pts{font-family:ui-monospace,SFMono-Regular,
  "SF Mono",Menlo,Consolas,monospace;
  font-size:.7rem;font-weight:600;letter-spacing:-.01em}
/* ── Trade-Journal ───────────────────────────────────────────────── */
.tj-filters{display:flex;flex-wrap:wrap;gap:10px}
.tj-filters label{display:flex;flex-direction:column;gap:3px;
  font-size:.7rem;color:var(--txt-sub);font-weight:600}
.tj-filters select{background:var(--bg-card);border:1px solid var(--brd);
  border-radius:6px;padding:6px 10px;color:var(--txt);font-size:.82rem;
  min-height:34px}
.tj-stats-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(140px,1fr));
  gap:8px;margin-top:4px}
.tj-stat{background:var(--bg-card);border:1px solid var(--brd);
  border-radius:8px;padding:8px 10px;display:flex;flex-direction:column;gap:2px}
.tj-stat-wide{grid-column:1 / -1}
.tj-stat-lbl{font-size:.65rem;text-transform:uppercase;letter-spacing:.4px;
  color:var(--txt-dim);font-weight:600}
.tj-stat-val{font-size:.92rem;font-weight:800;color:var(--txt);
  font-variant-numeric:tabular-nums}
.tj-trade{background:var(--bg-card);border:1px solid var(--brd);
  border-radius:8px;padding:10px 12px;margin-top:8px}
.tj-trade-win{border-left:3px solid #22c55e}
.tj-trade-loss{border-left:3px solid #ef4444}
.tj-trade-head{display:flex;flex-wrap:wrap;align-items:baseline;
  gap:8px;justify-content:space-between}
.tj-trade-ticker{font-size:.95rem;font-weight:800;color:var(--txt);
  letter-spacing:.01em}
.tj-trade-range{font-size:.74rem;color:var(--txt-sub);flex:1;min-width:0}
.tj-trade-pnl{font-size:.95rem;font-weight:800;font-variant-numeric:tabular-nums}
.tj-trade-meta{font-size:.74rem;color:var(--txt-sub);margin-top:4px;line-height:1.5}
.tj-trade-note{font-size:.78rem;color:var(--txt);margin-top:6px;
  padding:6px 10px;border-radius:6px;background:var(--bg-met);line-height:1.5}
.tj-trade-thesis{border-left:3px solid var(--accent)}
.tj-trade-lesson{border-left:3px solid #f59e0b}
.tj-note-lbl{display:inline-block;font-size:.62rem;text-transform:uppercase;
  letter-spacing:.5px;color:var(--txt-dim);font-weight:700;margin-right:6px}
/* Close-Form (Verkaufsdaten) — unterscheidet sich von Open-Form
   durch zusätzliche Textareas. Dasselbe pos-form-Grundgerüst. */
.pos-form-close textarea{background:var(--bg-met);border:1px solid var(--brd);
  border-radius:6px;padding:8px 10px;color:var(--txt);font-size:.82rem;
  font-family:inherit;line-height:1.4;resize:vertical;min-height:48px}
.pos-form-close textarea:focus{outline:2px solid var(--accent);outline-offset:1px}
/* Inline-Fehlermeldung im Position-Form — sichtbar im Panel selbst,
   unabhängig vom Watchlist-#wl-sync-warn-Element. */
.pos-form-err{background:rgba(239,68,68,0.12);border:1px solid rgba(239,68,68,0.45);
  color:#ef4444;border-radius:6px;padding:8px 10px;font-size:.78rem;
  line-height:1.45;margin-top:4px;font-weight:600}
/* Boni / Malus — kompakte Modifier-Pills */
.score-modifiers{display:grid;grid-template-columns:repeat(auto-fill,minmax(170px,1fr));
  gap:8px;margin-bottom:10px}
.score-mod-card{display:flex;align-items:center;justify-content:space-between;
  gap:8px;padding:8px 10px;border-radius:8px;
  background:var(--bg-card);border:1px solid var(--brd)}
.score-mod-bonus{border-left:3px solid #22c55e}
.score-mod-malus{border-left:3px solid #ef4444}
.score-mod-name{font-size:.74rem;color:var(--txt-sub);line-height:1.3}
.score-mod-val{font-size:.78rem;font-weight:800;color:var(--txt);
  font-variant-numeric:tabular-nums;flex-shrink:0;letter-spacing:.01em}
/* ── Color legend ── */
.color-legend{display:grid;grid-template-columns:1fr;gap:12px;margin-top:2px}
.cl-name{display:block;font-size:.67rem;text-transform:uppercase;letter-spacing:.5px;
  color:var(--accent);margin-bottom:5px;font-weight:700}
.color-bar{display:flex;border-radius:6px;overflow:hidden;height:22px;margin-bottom:6px}
.cb-seg{flex:1;display:flex;align-items:center;justify-content:center;
  font-size:.6rem;font-weight:700;color:#fff;text-shadow:0 1px 2px rgba(0,0,0,.45)}
.cl-desc{font-size:.77rem;color:var(--txt-sub);line-height:1.5;margin:0}
.info-box li strong{color:var(--txt)}
/* ── Disclaimer ── */
.disc{background:var(--bg-met);border:1px solid var(--brd);border-radius:8px;
  padding:10px 14px;margin-bottom:14px;font-size:.76rem;color:var(--disc-col);line-height:1.5}
/* ── Card grid: mobile 1-col (8px gap); ≥768px auto-fill (16px gap) ── */
.cards-grid{display:grid;grid-template-columns:1fr;gap:8px}
/* ── Card ── */
/* TopTen-Card 3D-Look (Variante 1B): kräftiger als Watchlist (Gradient
   2-Stops, 2px-Schatten, Inset-Highlight) — passend zur größeren Card-
   Fläche. ``border-radius:14px`` ersetzt das vormals globale
   ``var(--radius)`` (8px) für TopTen; andere Konsumenten der Variable
   sind unberührt. ``box-shadow`` ersetzt ``var(--shadow)`` analog. */
.card{background:linear-gradient(180deg,rgba(255,255,255,.05) 0%,rgba(0,0,0,.10) 100%) var(--bg-card);
  border:.5px solid var(--brd);border-radius:14px;
  box-shadow:0 2px 8px rgba(0,0,0,.08),inset 0 0 0 .5px rgba(255,255,255,.05);
  overflow:hidden}
.card-top{display:flex;align-items:flex-start;justify-content:space-between;
  padding:14px 14px 10px;gap:10px}
.card-left{display:flex;align-items:flex-start;gap:10px;flex:1;min-width:0}
.rank{display:flex;align-items:center;justify-content:center;width:28px;height:28px;
  border-radius:50%;background:var(--accent);color:#fff;font-size:.75rem;
  font-weight:800;flex-shrink:0;margin-top:3px}
/* Persönliche Watchlist-Karten: dezent dunkelgrüner Hintergrund + grüner Rand,
   im Dark-Mode deutlich sichtbar aber nicht grell */
.card-manual{background:rgba(20,83,45,0.35);border:1.5px solid rgba(74,222,128,0.6)}
/* Lazy-Rendering für Karten außerhalb des anfänglich sichtbaren Viewports:
   browser überspringt Layout/Paint bis Element nahe am Viewport ist.
   Nicht-unterstützende Browser rendern normal (graceful fallback). */
.card-lazy{content-visibility:auto;contain-intrinsic-size:auto 500px}
.ticker-block{flex:1;min-width:0}
.ticker-row{display:flex;align-items:center;gap:7px;flex-wrap:wrap;margin-bottom:3px}
.ticker{font-size:1.25rem;font-weight:800;font-family:'SF Mono','Courier New',monospace;color:var(--txt)}
.market-tag{font-size:.62rem;font-weight:700;background:var(--accent);color:#fff;
  padding:1px 6px;border-radius:4px;letter-spacing:.3px}
.chart-badge{display:inline-flex;align-items:center;justify-content:center;
  min-width:32px;min-height:32px;border-radius:6px;font-size:10px;font-weight:700;
  text-decoration:none;border:1.5px solid;padding:0 6px;line-height:1;box-sizing:border-box}
.chart-badge-y{background:#1d4ed8;color:#fff;border-color:#2563eb}
.chart-badge-y:hover{background:#1e40af}
.chart-badge-f{background:#4b5e7a;color:#fff;border-color:#5d7494}
.chart-badge-f:hover{background:#3b4d63}
.chart-badge-s{background:#7c3aed;color:#fff;border-color:#8b5cf6}
.chart-badge-s:hover{background:#6d28d9}
.chart-badge-dis{background:#334155;color:#94a3b8;border-color:#475569;
  cursor:default;pointer-events:none}
/* Stockanalysis-Outline-Button — ersetzt die alte ``.chart-badge-s``-Pille
   neben dem Tickersymbol. Outline-Stil mit External-Link-Icon + Text
   „Chart"; Border-Sub-Pixel über ``box-shadow`` simuliert (rendert auf
   Retina exakt 0.5 px). */
.sa-chart-btn{display:inline-flex;align-items:center;gap:4px;
  padding:3px 8px;border-radius:4px;
  background:transparent;color:var(--txt-sub);
  font-size:11px;font-weight:500;line-height:1.2;
  text-decoration:none;border:0;
  box-shadow:0 0 0 .5px var(--brd);
  transition:background .15s,color .15s,box-shadow .15s}
.sa-chart-btn svg{width:11px;height:11px;flex-shrink:0}
.sa-chart-btn:hover{background:var(--bg-met);color:var(--txt);
  box-shadow:0 0 0 .5px var(--txt-dim)}
.sa-chart-btn-dis{cursor:default;pointer-events:none;opacity:.45}
.price-tag{font-size:.82rem;font-weight:600}
.company{display:block;font-size:.78rem;color:var(--txt-sub);
  white-space:nowrap;overflow:hidden;text-overflow:ellipsis;max-width:100%}
.sector-tag{display:inline-block;font-size:.67rem;color:var(--txt-dim);margin-top:3px}
.earnings-tag{display:inline-block;font-size:.67rem;font-weight:600;margin-top:3px;margin-left:2px}
/* Feature 6 — Historische-Squeeze-Badge auf der Karte */
.squeeze-hist-badge{display:inline-block;font-size:.65rem;font-weight:700;color:#f59e0b;
  margin-top:3px;margin-left:4px;letter-spacing:.2px;cursor:help}
/* Feature 3 — P&D Warnbadges */
.pd-badge{display:inline-block;font-size:.65rem;font-weight:700;
  margin-top:3px;margin-left:4px;letter-spacing:.2px;cursor:help;
  padding:2px 6px;border-radius:4px;border:1px solid}
.pd-badge-warn{color:#f59e0b;background:#f59e0b18;border-color:#f59e0b55}
.pd-badge-risk{color:#ef4444;background:#ef444418;border-color:#ef444455;font-weight:800}
.pd-badge-pressure{color:#f97316;background:#f9731618;border-color:#f9731655}
.pd-badge-gamma{color:#eab308;background:#eab30820;border-color:#eab30866}
.pd-badge-gamma-strong{color:#ca8a04;background:#ca8a0428;border-color:#ca8a0488;font-weight:800}
/* Feature 1 — Sub-Scores unter dem Haupt-Score */
.sub-scores-wrap{border-top:1px solid var(--brd);background:var(--bg-met);padding:5px 14px 5px}
.sub-scores-header{font-size:.62rem;font-weight:800;color:var(--txt-dim);
  text-transform:uppercase;letter-spacing:.5px;line-height:1.1}
.sub-scores-hint{font-size:.58rem;color:var(--txt-dim);opacity:.75;line-height:1.2;
  margin-top:1px;margin-bottom:4px}
.sub-scores{display:flex;justify-content:space-between;gap:8px}
.sub-score{display:flex;flex-direction:column;align-items:center;flex:1;min-width:0;cursor:help}
.sub-score-lbl{font-size:.58rem;color:var(--txt-dim);text-transform:uppercase;
  letter-spacing:.3px;line-height:1.2}
.sub-score-val{font-size:.82rem;font-weight:800;line-height:1.3;margin-top:1px}
.sub-score-bar{display:block;width:100%;max-width:80px;height:2px;
  margin-top:3px;background:var(--brd);border-radius:1px;overflow:hidden}
.sub-score-fill{display:block;height:100%;border-radius:1px;
  transition:width .25s ease}
.wl-add-btn{background:none;border:none;color:var(--txt-dim);cursor:pointer;font-size:1rem;padding:0 3px;line-height:1;opacity:.55;transition:opacity .15s,color .15s}
.wl-add-btn:hover{color:#22c55e;opacity:1}
.wl-add-btn.in-wl{color:#22c55e;opacity:1}
.wl-section{display:block;margin-bottom:14px}
.wl-section-hdr{display:flex;align-items:center;gap:8px;padding:0 4px;margin-bottom:8px}
.wl-section-title{font-size:.9rem;font-weight:700;color:var(--txt)}
.wl-count-badge{font-size:.68rem;color:var(--txt-dim);background:var(--brd);padding:1px 7px;border-radius:10px}
/* Freitext-Eingabe für beliebige Ticker */
.wl-add-row{display:flex;gap:6px;margin-bottom:6px;padding:0 4px}
.wl-add-input{flex:1;min-width:0;background:var(--bg-card);border:1px solid var(--brd);
  border-radius:8px;color:var(--txt);padding:0 10px;height:36px;font-size:.85rem;
  font-family:'SF Mono','Courier New',monospace;text-transform:uppercase;letter-spacing:.5px}
.wl-add-input:focus{outline:2px solid var(--accent);outline-offset:1px;border-color:var(--accent)}
.wl-add-btn-manual{background:#16a34a;color:#fff;border:none;border-radius:8px;
  padding:0 14px;height:36px;font-size:.8rem;font-weight:700;cursor:pointer;white-space:nowrap;
  flex-shrink:0;transition:background .15s}
.wl-add-btn-manual:hover{background:#15803d}
.wl-add-btn-manual:active{transform:scale(.97)}
.wl-add-err{font-size:.75rem;color:#ef4444;background:#ef444418;border:1px solid #ef444444;
  border-radius:6px;padding:5px 10px;margin:0 4px 6px;display:none;line-height:1.4}
.wl-add-err.visible{display:block}
.wl-add-hint{font-size:.7rem;color:var(--txt-dim);padding:0 4px;margin-bottom:10px;line-height:1.45;
  font-style:italic}
/* Watchlist-Grid — kompakt, 6 Karten/Reihe Desktop, 3 Mobile (s.u.).
   Karten sind horizontal-Layout: Mini-Ring (Score) links, Ticker + Trend
   in Spalte 2; X-Button und ▾-Toggle absolute oben rechts / unten rechts. */
.wl-cards{display:grid;grid-template-columns:repeat(6,1fr);gap:8px}
.wl-card{background:linear-gradient(180deg,rgba(255,255,255,.04) 0%,rgba(0,0,0,.06) 100%) var(--bg-card);
  border:.5px solid var(--brd);border-radius:14px;position:relative;
  box-shadow:0 1px 3px rgba(0,0,0,.06),inset 0 0 0 .5px rgba(255,255,255,.04);
  min-height:58px;overflow:hidden;transition:box-shadow .15s,transform .1s}
.wl-card:hover{box-shadow:0 2px 6px rgba(0,0,0,.10),inset 0 0 0 .5px rgba(255,255,255,.06)}
/* Alle Watchlist-Kompaktkacheln bekommen dunkelgrünen Hintergrund +
   hellgrünen Rand. Specificity 0,2,0 schlägt die basis .wl-card-Regel. */
.wl-card.card-manual{background:rgba(20,83,45,0.35);border:1.5px solid rgba(74,222,128,0.6)}
/* Watchlist-Karte im aufgeklappten Drawer-Zustand: spannt eine ganze Grid-
   Reihe der ``.wl-cards``, läuft auf Desktop ÜBER die volle Reihen-Breite
   (kein 340px-Cap mehr) und erscheint mit 2-Spalten-Body — das ist die
   einzige Stelle im Frontend, an der das Voll-Breiten-Layout aktiv ist;
   reguläre TopTen-Karten bleiben kompakt im Grid. */
.wl-card--expanded{grid-column:1/-1;width:100%;justify-self:stretch;
  max-width:none;overflow:visible}
/* Expandierte Watchlist-Karte — kompakte Header-Zeile verstecken,
   Details-Body ohne Border-Top (Expanded ist jetzt die „ganze Karte") */
.wl-card--expanded > .wl-card-header{display:none}
.wl-card--expanded .wl-details-body{border-top:none}
/* Variante A: vorgerendertes TopTen-Layout im WL-Drawer.
   Das eingefügte HTML enthält bereits ``card-top``, ``sub-scores``,
   ``metrics-row`` etc. — die ``wl-details-body`` braucht weder Padding
   noch Inner-Border, weil die Innen-Elemente ihr eigenes Padding
   liefern. Im aufgeklappten Zustand ist die details-body bereits per
   ``open``-Klasse expandiert (max-height aus der Standard-Regel
   1200 px reicht für News + KI-Analyse + Drivers). */
.wl-card--expanded .wl-details-body{padding:0}
.wl-card--expanded .wl-details-body > .card-top{padding-top:10px}
/* Schließen-Bar oberhalb des inneren TopTen-Layouts. Sticky-Position
   sorgt dafür, dass der Schließen-Button auch in langen Karten
   zugänglich bleibt. */
.wl-exp-close-bar{position:sticky;top:0;z-index:5;
  background:var(--bg-card);
  border-bottom:1px solid var(--brd);
  padding:6px 10px;display:flex;justify-content:flex-end}
.wl-card.card-manual .wl-exp-close-bar{background:rgba(20,83,45,0.55)}
.wl-card--expanded .wl-exp-close-bar + .card-top{padding-top:6px}
/* 2-Spalten-Body für die expandierte Watchlist-Drawer-Karte. Reihenfolge
   der DOM-Kinder bleibt unverändert — explizite ``grid-column``-Zuweisung
   verteilt sie auf links/rechts. ``wl-exp-close-bar`` und ``card-top``
   spannen über beide Spalten (Header oben). */
.wl-card--expanded .wl-details-body{display:grid;grid-template-columns:1fr 1fr;
  column-gap:16px;align-items:start}
.wl-card--expanded .wl-details-body > .wl-exp-close-bar,
.wl-card--expanded .wl-details-body > .card-top{grid-column:1 / -1}
/* Linke Spalte: Setup-Analyse + Kennzahlen-Kacheln. */
.wl-card--expanded .wl-details-body > .sub-scores-wrap,
.wl-card--expanded .wl-details-body > .metrics-row{grid-column:1}
/* Rechte Spalte: Sparkline + Akkordeons + Position-Panel. */
.wl-card--expanded .wl-details-body > .spark-wrap,
.wl-card--expanded .wl-details-body > .details-btn,
.wl-card--expanded .wl-details-body > .details-body,
.wl-card--expanded .wl-details-body > .news-btn,
.wl-card--expanded .wl-details-body > .news-panel,
.wl-card--expanded .wl-details-body > .ki-analyse-btn,
.wl-card--expanded .wl-details-body > .ki-analyse-result,
.wl-card--expanded .wl-details-body > .position-panel{grid-column:2}
/* Schmale Displays: einspaltig (Mobile-Fallback). Breakpoint analog
   zum Top-10-Grid (``.cards-grid`` schaltet bei 768px auf auto-fill). */
@media (max-width: 767px) {
  .wl-card--expanded .wl-details-body{display:block;column-gap:0}
  .wl-card--expanded .wl-details-body > *{grid-column:auto}
}
/* ── Position-Panel (innerhalb expandierter Watchlist-Karte) ─── */
.position-panel{padding:12px 14px 14px;border-top:1px solid var(--brd);
  background:var(--bg-met)}
.position-panel-active{background:rgba(34,197,94,0.08);
  border-left:3px solid #22c55e}
.position-panel-empty,.position-panel-loading,.position-panel-disabled{
  background:rgba(148,163,184,0.06)}
.pos-header{font-size:.75rem;font-weight:700;text-transform:uppercase;
  letter-spacing:.5px;color:var(--txt-sub);margin-bottom:8px}
.pos-msg{font-size:.78rem;color:var(--txt-dim);line-height:1.5;margin-bottom:8px}
.pos-msg code{background:var(--bg-card);padding:1px 5px;border-radius:4px;
  font-size:.92em;border:1px solid var(--brd)}
.pos-grid{display:grid;grid-template-columns:1fr 1fr;gap:8px 14px;margin-bottom:10px}
.pos-grid > div{display:flex;flex-direction:column;gap:2px}
.pos-lbl{font-size:.66rem;text-transform:uppercase;letter-spacing:.4px;
  color:var(--txt-dim);font-weight:600}
.pos-val{font-size:.92rem;color:var(--txt);font-weight:600}
.pos-form{display:flex;flex-direction:column;gap:8px;
  margin-bottom:10px;padding:10px;background:var(--bg-card);
  border-radius:8px;border:1px solid var(--brd)}
.pos-lbl-form{display:flex;flex-direction:column;gap:3px;
  font-size:.72rem;color:var(--txt-sub);font-weight:600}
.pos-lbl-form input{background:var(--bg-met);border:1px solid var(--brd);
  border-radius:6px;padding:8px 10px;color:var(--txt);font-size:.85rem;
  min-height:36px}
.pos-lbl-form input:focus{outline:2px solid var(--accent);outline-offset:1px}
.pos-form-btns{display:flex;gap:6px;justify-content:flex-end;margin-top:4px}
.pos-actions{display:flex;flex-wrap:wrap;gap:6px}
.pos-btn{min-height:36px;padding:0 12px;border:1px solid var(--brd);
  border-radius:8px;font-size:.78rem;font-weight:700;cursor:pointer;
  background:var(--bg-card);color:var(--txt);flex:1 1 auto;white-space:nowrap}
.pos-btn:hover:not(:disabled){background:var(--brd)}
.pos-btn-open,.pos-btn-save{background:#16a34a;color:#fff;border-color:#16a34a}
.pos-btn-open:hover:not(:disabled),.pos-btn-save:hover:not(:disabled){background:#15803d}
.pos-btn-close{background:#1e3a5f;color:#93c5fd;border-color:#1e3a5f}
.pos-btn-close:hover:not(:disabled){background:#1e40af;color:#fff}
.pos-btn-cancel{background:transparent;color:var(--txt-sub)}
.pos-btn-remove{background:transparent;color:#ef4444;border-color:#ef444455;
  font-weight:600}
.pos-btn-remove:hover:not(:disabled){background:#ef444418}
/* Close-Button im expandierten Zustand (lila-passend zur KI-Thematik) */
.wl-close-btn-inline{background:var(--bg-met);color:var(--txt-sub);
  border:1px solid var(--brd);border-radius:8px;padding:4px 10px;
  font-size:.72rem;font-weight:600;cursor:pointer;white-space:nowrap;
  flex-shrink:0;margin-right:8px;min-height:32px}
.wl-close-btn-inline:hover{background:var(--brd);color:var(--txt)}
.wl-close-btn-inline:disabled{opacity:.45;cursor:not-allowed}
/* Kopfzeile im expandierten Watchlist-Card-Layout an Main-Card anpassen */
.wl-exp-top{display:flex;align-items:flex-start;justify-content:space-between;
  padding:10px 12px 8px;gap:10px}
/* Card-Header: horizontal — Mini-Ring + Ticker/Trend + KI-Dot.
   Card-wide Click-Hit ist das Header-Element selbst (cursor:pointer);
   ×- und ▾-Buttons stoppen Propagation. */
.wl-card-header{display:flex;align-items:center;gap:8px;
  padding:8px 10px 8px 8px;cursor:pointer;min-height:58px}
.wl-card-meta{display:flex;flex-direction:column;align-items:flex-start;
  gap:1px;flex:1;min-width:0}
.wl-card-ticker{font-size:11px;font-weight:500;color:var(--txt);
  letter-spacing:.01em;line-height:1.2;
  overflow:hidden;text-overflow:ellipsis;white-space:nowrap;max-width:100%}
.wl-card-trend{font-size:9px;font-weight:600;line-height:1}
/* Mini-Ring SVG — 34×34, r=14, circumference 88. */
.wl-ring{width:34px;height:34px;flex-shrink:0;display:block}
.wl-ring-bg{fill:none;stroke:var(--brd);stroke-width:2.5}
.wl-ring-fg{fill:none;stroke-width:2.5;stroke-linecap:round;
  transform:rotate(-90deg);transform-origin:50% 50%;
  transition:stroke-dashoffset .25s ease,stroke .15s}
.wl-ring-num{font-size:10px;font-weight:500;fill:var(--txt);
  dominant-baseline:middle}
.wl-badge-star{position:absolute;top:3px;left:5px;font-size:.55rem;
  color:#3b82f6;opacity:.7;pointer-events:none;z-index:1}
.wl-notop-badge{font-size:.62rem;color:#6b7280;background:#6b728022;
  border:1px solid #6b728044;border-radius:4px;padding:1px 5px;width:fit-content}
/* ▾-Toggle absolute unten-rechts, klein (kompaktes Layout). */
.wl-details-btn{position:absolute;bottom:2px;right:4px;
  background:none;border:none;color:var(--txt-dim);cursor:pointer;
  font-size:.7rem;padding:0;border-radius:4px;
  width:18px;height:18px;line-height:1;
  display:inline-flex;align-items:center;justify-content:center}
.wl-details-btn:hover{color:var(--accent);background:rgba(59,130,246,.10)}
.wl-details-body{border-top:1px solid var(--brd)}
.wl-no-data{padding:10px 14px;color:var(--txt-dim);font-size:.8rem;font-style:italic}
/* ×-Button absolute oben-rechts. Touch-Target via ::before-Overlay. */
.wl-remove-btn{position:absolute;top:2px;right:4px;
  background:none;border:none;color:var(--txt-dim);cursor:pointer;
  font-size:.85rem;line-height:1;opacity:.5;padding:0;
  width:18px;height:18px;display:inline-flex;
  align-items:center;justify-content:center;border-radius:4px}
.wl-remove-btn::before{content:"";position:absolute;inset:-8px;
  background:transparent}
.wl-remove-btn:hover,.wl-remove-btn:focus-visible{color:#ef4444;
  opacity:1;outline:none;background:rgba(239,68,68,.10)}

/* ── Mobile (≤768px): 3 Watchlist-Karten pro Reihe ──────────────
   Sonst übernimmt das Desktop-Grid (6 Karten/Reihe). Mini-Ring +
   horizontal-Layout bleiben unverändert. */
@media(max-width:768px){
  .wl-cards{grid-template-columns:repeat(3,1fr);gap:6px;width:100%;min-width:0}
  .wl-card{min-width:0}
  .wl-card-header{padding:6px 8px 6px 6px;gap:6px;min-height:54px}
  .wl-ring{width:30px;height:30px}
  .wl-card-ticker{font-size:10px}
  .wl-card-trend{font-size:8px}
  .wl-badge-star{display:none}
  .wl-card .agent-dot{transform:scale(.6);transform-origin:right center}
}
/* Alte 2-Spalten-Mobile-Regel (vor 30.04.) entfernt — siehe Block oben. */
.wl-sync-warn{font-size:.72rem;color:#f59e0b;background:#f59e0b18;border:1px solid #f59e0b44;
  border-radius:6px;padding:4px 8px;margin-bottom:6px;display:none}
.wl-sync-warn.visible{display:block}
/* ── Anthropic / Claude API ── */
.anth-panel{padding:0 0 10px}
.anth-panel .tok-hint{margin-bottom:6px}
.anth-panel .tok-row{flex-wrap:wrap;gap:6px}
.anth-status{font-size:.75rem;margin-top:6px;padding:6px 10px;border-radius:6px;display:none}
.anth-status.ok{background:#052a14;border:1px solid #166534;color:#86efac;display:block}
.anth-status.err{background:#2d0a0a;border:1px solid #991b1b;color:#fca5a5;display:block}
.btn-anth{background:#6d28d9;color:#fff;min-height:36px;padding:0 12px;font-size:.78rem}
.btn-anth:hover:not(:disabled){background:#5b21b6}
/* KI-Analyse per card */
.ki-analyse-btn{width:100%;min-height:44px;background:linear-gradient(90deg,#1e1040 0%,#2d1460 100%);
  border:none;border-top:1px solid #4c1d9522;color:#c4b5fd;font-size:.82rem;font-weight:600;
  cursor:pointer;padding:0 14px;text-align:left;display:flex;align-items:center;gap:6px;
  transition:background .15s}
.ki-analyse-btn:hover:not(:disabled){background:linear-gradient(90deg,#2d1460 0%,#3b1f6b 100%)}
.ki-analyse-btn:disabled{opacity:.5;cursor:not-allowed}
.ki-analyse-result{padding:10px 14px;
  padding-bottom:max(48px, env(safe-area-inset-bottom));
  border-top:1px solid #4c1d9522;display:none;
  font-size:.82rem;line-height:1.6;color:var(--txt-sub);background:#0d0920}
.ki-analyse-result.visible{display:block}
.ki-analyse-result .ka-label{font-size:.65rem;text-transform:uppercase;letter-spacing:.5px;
  color:#a78bfa;font-weight:700;margin-bottom:5px;display:flex;align-items:center;gap:8px}
.ka-rerun-btn{background:none;border:1px solid #4c1d95;color:#a78bfa;border-radius:6px;
  padding:1px 7px;font-size:.65rem;cursor:pointer;white-space:nowrap;flex-shrink:0}
.ka-rerun-btn:hover{background:#4c1d9533}
/* Chat panel — mobile full-screen, desktop right panel (380px) */
.btn-chat{background:#1e293b;color:#94a3b8;border:1px solid #334155}
.btn-chat:hover:not(:disabled){background:#334155;color:#e2e8f0}
.chat-panel{position:fixed;left:0;right:0;bottom:0;top:auto;height:100vh;width:100vw;
  background:var(--bg-card);border:1px solid var(--brd);box-shadow:0 -4px 24px rgba(0,0,0,.35);
  display:flex;flex-direction:column;z-index:300;
  transform:translateY(100%);transition:transform .28s cubic-bezier(.4,0,.2,1)}
.chat-panel.open{transform:translateY(0)}
@media(min-width:768px){
  .chat-panel{left:auto;top:0;width:380px;height:100vh;border-radius:0;
    transform:translateX(100%)}
  .chat-panel.open{transform:translateX(0)}
}
.chat-hdr{display:flex;align-items:center;padding:12px 16px;border-bottom:1px solid var(--brd);
  gap:10px;flex-shrink:0;background:var(--bg-hdr)}
.chat-hdr-title{flex:1;font-size:.95rem;font-weight:700;color:var(--txt)}
.chat-close-btn{background:none;border:none;color:var(--txt-dim);cursor:pointer;font-size:1.4rem;
  padding:0;line-height:1;min-width:48px;min-height:48px;width:48px;height:48px;
  display:flex;align-items:center;justify-content:center;border-radius:8px;flex-shrink:0;
  position:relative;z-index:9999;touch-action:manipulation;-webkit-tap-highlight-color:transparent}
.chat-close-btn:hover{color:var(--txt);background:var(--bg-met)}
.chat-close-btn:active{background:var(--bg-met)}
.chat-overlay{position:fixed;inset:0;background:rgba(0,0,0,.45);z-index:299;
  display:none;-webkit-tap-highlight-color:transparent;cursor:pointer;touch-action:manipulation}
.chat-overlay.open{display:block}
.chat-footer-close{position:sticky;bottom:0;padding:10px 12px;background:var(--bg-card);
  border-top:2px solid #3b82f680;flex-shrink:0;z-index:1}
.chat-footer-close button{width:100%;min-height:48px;background:#0e3a5e;border:1px solid #3b82f6;
  color:#93c5fd;border-radius:10px;font-size:.92rem;font-weight:600;cursor:pointer;
  touch-action:manipulation;-webkit-tap-highlight-color:transparent;letter-spacing:.3px}
.chat-footer-close button:active{background:#1e40af}
.chat-warn-banner{padding:10px 14px;background:#1c1200;border:1px solid #92400e;color:#fcd34d;
  font-size:.78rem;line-height:1.5;margin:10px 12px 0;border-radius:8px}
.chat-warn-banner.hidden{display:none}
.chat-warn-banner .btn{margin-top:8px;min-height:32px;padding:0 12px;font-size:.78rem;
  background:#f59e0b;color:#1c1102;flex:0 0 auto}
.chat-msgs{flex:1;min-height:0;overflow-y:auto;-webkit-overflow-scrolling:touch;
  overscroll-behavior:contain;padding:12px 14px;display:flex;flex-direction:column;gap:10px}
.chat-msg{max-width:88%;padding:9px 13px;border-radius:10px;font-size:.85rem;line-height:1.55;
  word-wrap:break-word}
.chat-msg--user{align-self:flex-end;background:#1e3a5f;color:#bae6fd;border-radius:10px 10px 2px 10px}
.chat-msg--ai{align-self:flex-start;background:var(--bg-met);color:var(--txt);border-radius:10px 10px 10px 2px}
.chat-msg--sys{align-self:center;color:var(--txt-dim);font-size:.72rem;font-style:italic;text-align:center}
.chat-msg--err{align-self:center;background:#2d0a0a;border:1px solid #991b1b;color:#fca5a5;
  border-radius:8px;font-size:.78rem}
.chat-msg.streaming::after{content:'▋';color:var(--accent);animation:chatCaret 1s steps(2) infinite}
@keyframes chatCaret{50%{opacity:0}}
.chat-chips{display:flex;flex-wrap:wrap;gap:6px;padding:8px 12px;border-top:1px solid var(--brd);flex-shrink:0}
.chip{background:var(--bg-met);border:1px solid var(--brd);border-radius:20px;
  padding:5px 11px;font-size:.72rem;cursor:pointer;color:var(--txt-sub);white-space:nowrap;
  text-align:left}
.chip:hover{background:var(--brd);color:var(--txt)}
.chat-input-row{display:flex;gap:6px;padding:10px 12px;border-top:1px solid var(--brd);flex-shrink:0;
  padding-bottom:max(10px,env(safe-area-inset-bottom))}
.chat-inp{flex:1;background:var(--bg-met);border:1px solid var(--brd);border-radius:8px;
  color:var(--txt);padding:0 12px;height:42px;font-size:.85rem;font-family:inherit}
.chat-inp:focus{outline:2px solid var(--accent);outline-offset:1px}
.chat-send-btn{background:#2563eb;color:#fff;border:none;border-radius:8px;
  padding:0 16px;height:42px;font-size:.95rem;font-weight:700;cursor:pointer;flex-shrink:0}
.chat-send-btn:hover:not(:disabled){background:#1d4ed8}
.chat-send-btn:disabled{opacity:.45;cursor:not-allowed}
.score-block{display:flex;flex-direction:column;align-items:flex-end;gap:7px;min-width:80px}
.sb-row{display:flex;flex-direction:column;align-items:flex-end;line-height:1}
.sb-num{font-weight:400;line-height:1;font-size:22px;
  user-select:none;-webkit-tap-highlight-color:transparent}
.sb-row[data-sb="setup"] .sb-num{cursor:pointer}
.sb-row[data-sb="setup"] .sb-num:hover,
.sb-row[data-sb="setup"] .sb-num:focus-visible{opacity:.85;outline:none}
.sb-lbl{font-size:.58rem;color:var(--txt-dim);text-transform:uppercase;
  letter-spacing:.4px;margin:3px 0 4px;font-weight:700}
.sb-track{width:70px;height:4px;background:var(--brd);border-radius:3px;overflow:hidden}
.sb-fill{height:100%;border-radius:3px;transition:width .3s,background .3s}
.score-block.sort-setup .sb-row[data-sb="setup"]{order:1}
.score-block.sort-setup .sb-row[data-sb="monster"]{order:2}
.score-block.sort-setup .sb-row[data-sb="ki"]{order:3}
.score-block.sort-setup .sb-row[data-sb="setup"] .sb-num{font-size:36px;font-weight:900}
.score-block.sort-monster .sb-row[data-sb="monster"]{order:1}
.score-block.sort-monster .sb-row[data-sb="setup"]{order:2}
.score-block.sort-monster .sb-row[data-sb="ki"]{order:3}
.score-block.sort-monster .sb-row[data-sb="monster"] .sb-num{font-size:36px;font-weight:900}
/* Legacy aliases — old class names kept as no-op fallback for cached pages.
   ``cursor: default`` (statt pointer): Setup-Score reagiert nicht mehr
   auf Klicks — die Tooltip-Erklärung ist entfallen, alle Werte stehen
   sichtbar auf der Karte. */
.score-num{font-size:1.7rem;font-weight:900;line-height:1;cursor:default;
  user-select:none;-webkit-tap-highlight-color:transparent}
.score-lbl{font-size:.62rem;color:var(--txt-dim);text-transform:uppercase;
  letter-spacing:.4px;margin-bottom:5px}
.score-track{width:60px;height:5px;background:var(--brd);border-radius:3px}
.score-fill{height:100%;border-radius:3px;transition:width .3s}
.score-hist-lbl{font-size:.58rem;color:var(--txt-dim);margin-top:2px;text-align:center}
.score-below-min{display:block;font-size:.58rem;color:var(--txt-dim);margin-top:3px;
  text-align:right;font-style:italic;line-height:1.3;max-width:68px}
/* ── Sparkline ── */
.spark-wrap{padding:8px 12px 4px;border-top:1px solid var(--brd)}
.spark-header{display:flex;justify-content:space-between;align-items:center;margin-bottom:4px;gap:8px}
.spark-title-wrap{display:flex;flex-direction:column;min-width:0;flex:1}
.spark-title{font-size:.68rem;color:var(--txt);text-transform:uppercase;letter-spacing:.3px;font-weight:700}
.spark-subtitle{font-size:.58rem;color:var(--txt-dim);font-style:italic;margin-top:1px;
  white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.spark-trend{font-size:13px;font-weight:700;flex-shrink:0}
.spark-svg-wrap{width:100%;height:60px;position:relative}
.spark-svg-wrap svg{width:100%;height:60px;overflow:visible}
.spark-days{position:relative;height:14px;margin-top:2px}
.spark-day-lbl{position:absolute;font-size:.58rem;color:var(--txt-dim);
  transform:translateX(-50%);white-space:nowrap;line-height:1}
.spark-day-lbl.ghost{color:#6b7280}
.spark-placeholder{font-size:.7rem;color:var(--txt-dim);font-style:italic;
  padding:8px 12px 6px;border-top:1px solid var(--brd)}
/* Sparkline tooltip — Multi-line Variante mit Driver-Historie pro Tag.
   Position: oberhalb des Sparkline-SVG, horizontal zentriert auf den
   getriggerten Punkt (left wird per JS gesetzt + clamped). */
.spark-wrap{position:relative}
.spark-tip{position:absolute;background:var(--bg-card);border:1px solid var(--brd);
  border-radius:7px;padding:5px 9px;font-size:.7rem;color:var(--txt);
  pointer-events:none;z-index:20;max-width:240px;line-height:1.35;
  box-shadow:0 4px 12px rgba(0,0,0,.35);
  transform:translate(-50%,-110%);opacity:0;transition:opacity .15s}
.spark-tip.visible{opacity:1}
.spark-tip-head{display:flex;justify-content:space-between;gap:8px;
  font-size:.7rem;border-bottom:1px solid var(--brd);
  padding-bottom:3px;margin-bottom:4px}
.spark-tip-date{color:var(--txt-sub);font-weight:600}
.spark-tip-score{font-weight:800;font-variant-numeric:tabular-nums}
.spark-tip-drv{list-style:none;margin:0;padding:0;display:flex;
  flex-direction:column;gap:2px}
.spark-tip-drv li{position:relative;padding-left:10px;font-size:.7rem;
  color:var(--txt);line-height:1.4}
.spark-tip-drv li::before{content:"•";position:absolute;left:0;color:var(--accent)}
.spark-tip-no{color:var(--txt-dim);font-style:italic;font-size:.68rem}
.sp-hit{cursor:pointer}
/* ── Metrics — Mobile: 2-Spalten-Grid, Short-Float-Header volle Breite ── */
/* 6 gleich große Kacheln: 3×2 auf iPhone + Desktop (SF oben-links, dann DTC/Vol/Mom/Float/SI-Trend) */
.metrics-row{display:grid;grid-template-columns:repeat(3,1fr);gap:6px;padding:0 12px 12px}
.metric-box{background:var(--bg-met);border:1px solid var(--brd);border-radius:10px;
  padding:10px 6px;text-align:center;border-top:3px solid var(--mc,#94a3b8);position:relative}
.m-val{display:block;font-size:1.1rem;font-weight:800;color:var(--mc,#94a3b8)}
.m-lbl{display:block;font-size:.62rem;color:var(--txt-dim);text-transform:uppercase;
  letter-spacing:.3px;margin-top:2px}
.si-badge{position:absolute;top:4px;right:5px;font-size:9px;font-weight:700;line-height:1}
.si-badge-up{color:#22c55e}
.si-badge-down{color:#ef4444}
.si-badge-side{color:#f59e0b}
/* ── KI-Agent Status & Signal Dots ── */
.agent-status-bar{font-size:.72rem;color:var(--txt-dim);padding:4px 14px 8px;
  letter-spacing:.1px}
.agent-dot{display:inline-block;border-radius:50%;
  margin-left:5px;vertical-align:middle;cursor:pointer;position:relative}
.agent-dot.strong  {width:12px;height:12px;--pc:#22c55e88;background:#22c55e;animation:pulse 1s   ease-out infinite}
.agent-dot.moderate{width:11px;height:11px;--pc:#f59e0b88;background:#f59e0b;animation:pulse 1.5s ease-out infinite}
.agent-dot.weak    {width:10px;height:10px;--pc:#ef444488;background:#ef4444;animation:pulse 2s   ease-out infinite}
.agent-dot.none    {width:8px; height:8px; background:#6b7280}
@keyframes pulse{
  0%  {box-shadow:0 0 0 0   var(--pc)}
  70% {box-shadow:0 0 0 8px transparent}
  100%{box-shadow:0 0 0 0   transparent}
}
@media(max-width:480px){
  .agent-dot.strong  {width:14px;height:14px}
  .agent-dot.moderate{width:13px;height:13px}
  .agent-dot.weak    {width:12px;height:12px}
  .agent-dot.none    {width:10px;height:10px}
}
/* Agent-Dot-Tooltip ist entfallen — siehe ``renderAgentSignals`` in
   generate_report.py. Der Punkt selbst signalisiert genug. */
/* ── Detail table (top of details body) ── */
.detail-table-wrap{padding:10px 12px 8px}
/* ── Drivers block (Synthese-Zeile + kategorisierte Stärken/Risiken) ── */
.drivers-block{padding:10px 12px 12px;border-top:1px solid var(--brd)}
.drivers-header{display:flex;align-items:center;justify-content:flex-end;
  margin-bottom:6px}
.risk-badge{flex-shrink:0;padding:4px 10px;border-radius:20px;font-size:.7rem;
  font-weight:700;letter-spacing:.4px;border:1px solid;white-space:nowrap}
.drivers-synthesis{font-size:.86rem;color:var(--txt-sub);line-height:1.55;
  margin:0 0 10px;padding:8px 10px;background:var(--bg-met);border-radius:6px;
  border-left:3px solid var(--accent)}
.drivers-synthesis .syn-pos{color:#22c55e;font-weight:700;margin-right:2px}
.drivers-synthesis .syn-neg{color:#ef4444;font-weight:700;margin-right:2px}
.drivers-cats{display:grid;grid-template-columns:1fr;gap:8px}
@media(min-width:480px){.drivers-cats{grid-template-columns:1fr 1fr}}
.drivers-cat{background:var(--bg-met);border-radius:6px;padding:8px 10px;
  border:1px solid var(--brd)}
.drivers-strengths{border-left:3px solid #22c55e}
.drivers-risks{border-left:3px solid #ef4444}
.drivers-cat-hdr{font-size:.68rem;text-transform:uppercase;letter-spacing:.06em;
  font-weight:700;margin-bottom:6px;color:var(--txt-sub)}
.drivers-strengths .drivers-cat-hdr{color:#22c55e}
.drivers-risks    .drivers-cat-hdr{color:#ef4444}
.drivers-list{list-style:none;margin:0;padding:0;display:flex;flex-direction:column;
  gap:3px}
.drivers-list li{display:flex;align-items:baseline;gap:8px;font-size:.82rem;
  line-height:1.4;color:var(--txt)}
.drv-w{flex-shrink:0;min-width:30px;font-variant-numeric:tabular-nums;
  font-weight:700;font-size:.74rem;text-align:right}
.drv-w-pos{color:#22c55e}
.drv-w-neg{color:#ef4444}
.drv-lbl{color:var(--txt-sub)}
/* ── Details dropdown button ── */
.details-btn{width:100%;min-height:44px;background:var(--bg-met);
  border:none;border-top:1px solid var(--brd);border-bottom:none;
  color:var(--txt-sub);font-size:.82rem;font-weight:600;cursor:pointer;
  padding:0 14px;text-align:left;display:flex;align-items:center;gap:6px}
.details-btn:hover{background:var(--brd)}
.details-arrow{display:inline-block;font-size:.75rem;transition:transform .2s ease;
  flex-shrink:0}
/* Akkordeon-Indikator: Chevron rotiert um 180° beim Öffnen — gilt für
   alle drei Toggle-Buttons. Steuerung rein per ``.is-open``-Klasse, kein
   Inline-``style.transform``-Setzen mehr. */
.details-btn.is-open .details-arrow{transform:rotate(180deg)}
.news-arrow{display:inline-block;font-size:.75rem;transition:transform .2s ease;
  flex-shrink:0}
.news-btn.is-open .news-arrow{transform:rotate(180deg)}
.ki-analyse-btn::before{content:"\25BC";display:inline-block;
  font-size:.75rem;margin-right:6px;transition:transform .2s ease}
.ki-analyse-btn.is-open::before{transform:rotate(180deg)}
/* ── Collapsible details body ── */
.details-body{max-height:0;overflow:hidden;
  transition:max-height .25s ease}
.details-body.open{max-height:1200px}
/* ── News toggle button ── */
.news-btn{width:100%;min-height:44px;background:var(--bg-met);border:none;
  border-top:1px solid var(--brd);color:var(--txt-sub);font-size:.82rem;
  font-weight:600;cursor:pointer;padding:0 14px;text-align:left;display:flex;
  align-items:center;gap:6px}
.news-btn:hover{background:var(--brd)}
/* ── News panel ── */
.news-panel{border-top:1px solid var(--brd);padding:12px 14px}
.ki-signal-block{border-bottom:1px solid var(--brd);padding:0 0 10px;margin-bottom:10px;display:none}
.ki-signal-header{font-size:.72rem;font-weight:700;color:#f59e0b;letter-spacing:.4px;margin-bottom:5px}
.ki-signal-body{display:flex;flex-direction:column;gap:3px}
.ki-score{font-size:.82rem;font-weight:700;color:var(--txt)}
.ki-confidence{font-size:.75rem;color:#f59e0b;font-weight:600}
.ki-drivers{font-size:.78rem;color:var(--txt-sub)}
.ki-meta{font-size:.68rem;color:var(--txt-dim)}
.news-items{margin-bottom:12px}
.ni{margin-bottom:10px;font-size:.93rem;line-height:1.5}
.ni a{color:var(--accent);display:block;margin-bottom:2px}
.ni a:hover{text-decoration:underline}
.ni-meta{font-size:.7rem;color:var(--txt-dim)}
.ni-src{font-size:.72rem;color:var(--txt-dim);font-style:italic}
.no-news{font-size:.93rem;color:var(--txt-dim)}
.no-data-notice{font-size:.75rem;color:var(--txt-dim);font-style:italic;
  margin:4px 12px 10px;padding:6px 10px;background:var(--bg-met);border-radius:6px;
  border-left:3px solid var(--brd)}
.news-summary-box{background:var(--bg-met);border-radius:8px;padding:10px 12px;margin-bottom:12px}
.summary-label{display:block;font-size:.65rem;text-transform:uppercase;letter-spacing:.5px;
  color:var(--accent);margin-bottom:5px;font-weight:700}
.summary-text{font-size:.93rem;color:var(--txt-sub);line-height:1.6}
.detail-table{width:100%;font-size:.78rem;border-collapse:collapse}
.detail-table td{padding:4px 0;border-bottom:1px solid var(--brd)}
.detail-table td:first-child{color:var(--txt-dim);padding-right:10px}
.detail-table td:last-child{text-align:right;font-weight:600;color:var(--txt)}
/* Sub-Header zur visuellen Gruppierung der Detail-Zeilen — kein Akkordeon,
   nur dezente Trennung. Erste Zeile ohne border-top, damit der Rahmen
   nicht doppelt mit der Tabellen-Oberkante kollidiert. */
.detail-table tr.detail-group-header td{
  padding:14px 0 4px;border-bottom:0;border-top:1px solid var(--brd);
  font-size:.66rem;letter-spacing:.09em;text-transform:uppercase;
  color:var(--txt-dim);font-weight:700;text-align:left}
.detail-table tr.detail-group-header:first-child td{border-top:0;padding-top:6px}
/* ── Footer – full width ── */
.footer{padding:16px 14px 32px;
  border-top:1px solid var(--brd);text-align:center}
.footer p{font-size:.73rem;color:var(--txt-dim);line-height:1.6;margin-bottom:4px}
/* ══ RESPONSIVE ═════════════════════════════════════════════════════════════
   ≥ 768 px  Tablet / kleiner Desktop
   ═════════════════════════════════════════════════════════════════════════ */
@media(min-width:768px){
  /* Header single row: title (links) | timestamp (zentriert) | hamburger (rechts).
     Identische Hamburger-Logik wie Mobile — Drawer-Breite via @media oben
     auf 320 px; sticky/scroll-shadow gilt bereits universell. */
  .hdr-main{flex-wrap:nowrap;padding:0;height:60px;gap:12px}
  /* Desktop: Title prominenter — größer + stärker.
     Mobile (default 1.05rem, weight 800) unverändert. */
  .app-title{order:1;flex:0 0 auto;font-size:1.85rem;font-weight:900;letter-spacing:-.01em}
  .hdr-ts{order:2;flex:1;width:auto;text-align:center}
  .hamburger-btn{order:3}
  /* Info panel: 3 columns */
  .info-inner{grid-template-columns:repeat(3,1fr)}
  .color-legend{grid-template-columns:repeat(2,1fr)}
  /* Cards: fluid auto-fill, min 340px per card, 16px gap, full width */
  .cards-grid{grid-template-columns:repeat(auto-fill,minmax(340px,1fr));gap:16px}
  .stats-bar{grid-template-columns:repeat(6,1fr)}
  .wrap{padding:16px 16px 32px}
  .footer{padding:16px 16px 32px}
  /* Slightly smaller body text */
  .drivers-synthesis{font-size:.78rem}
  .drivers-list li{font-size:.78rem}
  .ni,.no-news,.summary-text{font-size:.82rem}
}
/* ══ ≥ 1200 px  großer Desktop / Wide-Screen ════════════════════════════════ */
@media(min-width:1200px){
  .app-hdr{padding:0 24px}
  .hdr-main{height:52px;gap:10px}
  .wrap{padding:24px 24px 40px}
  .footer{padding:24px 24px 40px}
}
.edgar-link{color:var(--accent);text-decoration:none}
.edgar-link:hover{text-decoration:underline}
/* ══ Druckansicht ════════════════════════════════════════════════════════════ */
@media print{
  /* Reset colours to print-friendly light theme */
  :root{
    --bg:#fff;--bg-card:#fff;--bg-hdr:#fff;--bg-met:#f5f5f5;
    --txt:#000;--txt-sub:#444;--txt-dim:#666;
    --brd:#ccc;--shadow:none;--accent:#1a56db;
  }
  html[data-theme="dark"]{
    --bg:#fff;--bg-card:#fff;--bg-hdr:#fff;--bg-met:#f5f5f5;
    --txt:#000;--txt-sub:#444;--txt-dim:#666;
    --brd:#ccc;--shadow:none;
  }
  /* Hide interactive / non-content elements */
  .app-hdr,.hamburger-btn,.menu-drawer,.menu-overlay,
  .tok-panel,#amsg,
  .details-btn,.news-btn,.tok-link,
  [id^="tok-"]{display:none!important}
  /* Show all collapsed sections */
  .details-body,.news-panel{display:block!important;height:auto!important;
    overflow:visible!important;visibility:visible!important}
  [hidden]{display:block!important}
  /* Page layout */
  body{background:#fff;font-size:11pt;color:#000}
  .wrap{padding:8px 0}
  .card{break-inside:avoid;page-break-inside:avoid;
    border:1px solid #ccc;border-radius:0;box-shadow:none;
    margin-bottom:12pt;padding:10pt}
  .stats-bar{break-inside:avoid;page-break-inside:avoid}
  .info-panel{break-inside:avoid;page-break-inside:avoid}
  /* Make sparkline section take less space */
  .spark-wrap{max-height:90px;overflow:hidden}
  /* Score track bar via background-color not CSS var */
  .score-fill{print-color-adjust:exact;-webkit-print-color-adjust:exact}
  /* Badges and colour indicators — keep colours in print */
  .metric-box,.score-num,.risk-badge,
  [style*="color:"]{print-color-adjust:exact;-webkit-print-color-adjust:exact}
  /* Print header with report title + date */
  .app-title{display:block!important;font-size:14pt;font-weight:800;margin-bottom:4pt}
  .hdr-ts{display:block!important;font-size:9pt;color:#444}
  /* Ensure links are visible in print */
  a[href]::after{content:" (" attr(href) ")";font-size:7pt;color:#666;word-break:break-all}
  a.chart-badge::after{content:none}
}
</style>
</head>